# Database (Vercel Postgres 또는 Supabase, Neon 등)
DATABASE_URL="postgresql://..."

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"  # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# Gemini API (Google AI Studio에서 발급)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# 카카오 OAuth
# https://developers.kakao.com → 내 애플리케이션 → 앱 추가
# 플랫폼 → Web → 사이트 도메인 등록
# 카카오 로그인 → Redirect URI: http://localhost:3000/api/auth/callback/kakao
# 동의항목: profile_nickname, profile_image, account_email
KAKAO_CLIENT_ID="your-kakao-rest-api-key"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"  # 보안 → Client Secret (선택)

# 네이버 OAuth
# https://developers.naver.com → Application → 애플리케이션 등록
# 사용 API: 네아로(네이버 아이디로 로그인) 선택
# Callback URL: http://localhost:3000/api/auth/callback/naver
NAVER_CLIENT_ID="your-naver-client-id"
NAVER_CLIENT_SECRET="your-naver-client-secret"

# Notion OAuth
# https://www.notion.so/my-integrations 에서 발급
NOTION_CLIENT_ID="your-notion-client-id"
NOTION_CLIENT_SECRET="your-notion-client-secret"
NOTION_REDIRECT_URI="http://localhost:3000/api/notion/callback"
