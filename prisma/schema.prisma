datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  name             String?
  image            String?
  notionToken      String?
  notionPageId     String?
  createdAt        DateTime  @default(now())

  // ✅ 구독 관련 필드 추가
  subscriptionStatus String  @default("free")   // "free" | "premium" | "cancelled"
  subscriptionEnd  DateTime?
  billingKey       String?   // 토스페이먼츠 자동결제 빌링키
  monthlyUsage     Int       @default(0)         // 이번 달 기도 생성 횟수
  usageResetDate   DateTime  @default(now())     // 사용량 초기화 기준일

  prayerLogs       PrayerLog[]
  subscriptions    Subscription[]
  accounts         Account[]
  sessions         Session[]
}

// ✅ 구독 결제 내역 모델
model Subscription {
  id               String   @id @default(cuid())
  userId           String
  plan             String   @default("premium")  // "premium"
  status           String   // "active" | "cancelled" | "expired"
  amount           Int      @default(9900)        // 원 단위
  startDate        DateTime @default(now())
  endDate          DateTime
  tossOrderId      String?  @unique
  tossPaymentKey   String?
  billingKey       String?
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id])
}

model PrayerLog {
  id           String   @id @default(cuid())
  userId       String
  situation    String
  prayerType   String   @default("간구")
  categories   Json
  scriptures   Json
  notionPageId String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
